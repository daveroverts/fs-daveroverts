{
  "name": "fs-daveroverts",
  "description": "Just some random flight simulator website by Dave Roverts",
  "version": "1.0.0",
  "author": {
    "name": "Dave Roverts",
    "email": "me@daveroverts.nl",
    "url": "https://www.daveroverts.nl"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daveroverts/fs-daveroverts.git"
  },
  "scripts": {
    "dev": "next --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@heroicons/react": "2.2.0",
    "@plaiceholder/next": "3.0.0",
    "date-fns": "4.1.0",
    "fathom-client": "3.7.2",
    "gray-matter": "4.0.3",
    "next": "16.2.10",
    "next-mdx-remote": "6.0.0",
    "next-themes": "0.4.6",
    "plaiceholder": "3.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-lite-youtube-embed": "3.5.1",
    "rehype-external-links": "3.0.0",
    "sharp": "0.34.5",
    "swr": "2.4.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/typography": "0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "husky": "9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "8.5.15",
    "prettier": "^3.8.4",
    "tailwindcss": "4.3.2",
    "vitest": "^4.1.9"
  }
}
